# Byte-compiled / optimized / DLL files
__pycache__/
*.py[codz]
*$py.class

# C extensions
*.so

# Distribution / packaging
# NOTE: lib/ and lib64/ are anchored to the project root (leading /) -- unanchored,
# they match at any depth and were silently swallowing edenview-ui/src/lib/ (api.ts,
# utils.ts, types.ts, pipeline-state.ts), which meant those files were NEVER actually
# committed to git despite existing on disk here -- a fresh clone was missing them
# outright ("Module not found: Can't resolve '@/lib/api'"). Root-anchoring is safe:
# this project has no build-artifact lib/ at the root anyway (venv/ and build/ below
# already cover the cases the unanchored pattern was meant for).
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
/lib/
/lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# PyInstaller
#   Usually these files are written by a python script from a template
#   before PyInstaller builds the exe, so as to inject date/other infos into it.
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py.cover
.hypothesis/
.pytest_cache/
cover/

# Translations
*.mo
*.pot

# Django stuff:
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal

# Flask stuff:
instance/
.webassets-cache

# Scrapy stuff:
.scrapy

